{
  "name": "pnpm-catalog-manager",
  "displayName": "pnpm-catalog-manager",
  "version": "1.0.2",
  "description": "Manage pnpm catalog dependencies with version checking",
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/salmin89/pnpm-catalog-manager"
  },
  "publisher": "SalminCode",
  "type": "module",
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "contributes": {
    "commands": [
      {
        "command": "pnpm-catalog-manager.refresh",
        "title": "PNPM Catalog: Refresh Outdated Packages"
      },
      {
        "command": "pnpm-catalog-manager.updateToLatest",
        "title": "PNPM Catalog: Update Package to Latest"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:yaml"
  ],
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.100.0"
  }
}
